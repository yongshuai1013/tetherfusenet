  <string
    name="editmode_hotspot_proxy_newengine_description"
  >The New Engine uses a single port for all connection types, so different port numbers for HTTP and SOCKS are no longer required.</string>

  <string name="editmode_hotspot_proxy_http_title">HTTP/HTTPS Proxy</string>
  <string name="editmode_hotspot_proxy_http_description">
    This proxy mode is simple and fast. It is compatible with most webpages
    but not all online services like games, chat, or video streaming.
    Most users will want to use this option (recommended)
  </string>

  <string
    name="editmode_hotspot_proxy_socks_title"
  >SOCKS4A/SOCKS5H Proxy</string>
  <string name="editmode_hotspot_proxy_socks_description">
    This proxy mode is slower and is only meant for highly technical
    users and specific use-cases.
    This proxy mode supports SOCKS4A, SOCKS5 (CONNECT and UDP-ASSOCIATE).
    Most users will not need this option.
  </string>
